# Weather Bot Configuration Template
# Copy this file to .env and fill in your values

# =============================================================================
# CRITICAL: Polymarket CLOB API (Required for live trading)
# =============================================================================
# Get these from https://polymarket.com/portfolio
POLYMARKET_PRIVATE_KEY=0x...
POLYMARKET_API_KEY=...
POLYMARKET_API_SECRET=...
POLYMARKET_API_PASSPHRASE=...
POLYMARKET_CLOB_CHAIN_ID=137
POLYMARKET_CLOB_HOST=https://clob.polymarket.com

# =============================================================================
# Kalshi API (Optional - if you want Kalshi markets)
# =============================================================================
KALSHI_API_KEY_ID=
KALSHI_PRIVATE_KEY_PATH=
KALSHI_ENABLED=false

# =============================================================================
# AI Configuration (Optional - for AI insights)
# =============================================================================
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
AI_LOG_ALL_CALLS=true
AI_DAILY_BUDGET_USD=1.0

# =============================================================================
# Bot Settings
# =============================================================================
# Set to false for live trading with real money
SIMULATION_MODE=true
INITIAL_BANKROLL=10000.0
KELLY_FRACTION=0.15

# =============================================================================
# Weather Trading
# =============================================================================
WEATHER_ENABLED=true
WEATHER_SCAN_INTERVAL_SECONDS=300
WEATHER_SETTLEMENT_INTERVAL_SECONDS=1800
WEATHER_MIN_EDGE_THRESHOLD=0.08
WEATHER_MAX_ENTRY_PRICE=0.70
WEATHER_MAX_TRADE_SIZE=100.0

# =============================================================================
# Order Management (Dynamic Stop-Loss)
# =============================================================================
ORDER_MANAGEMENT_ENABLED=true
ORDER_MANAGEMENT_INTERVAL_SECONDS=300
ORDER_MIN_EDGE_THRESHOLD=0.08
ORDER_PRICE_CHANGE_THRESHOLD=0.30

# =============================================================================
# BTC 5-Min Trading
# =============================================================================
SCAN_INTERVAL_SECONDS=60
SETTLEMENT_INTERVAL_SECONDS=120
BTC_PRICE_SOURCE=coinbase
MIN_EDGE_THRESHOLD=0.02
MAX_ENTRY_PRICE=0.55
MAX_TRADES_PER_WINDOW=1
MAX_TOTAL_PENDING_TRADES=20

# =============================================================================
# Risk Management
# =============================================================================
DAILY_LOSS_LIMIT=300.0
MAX_TRADE_SIZE=75.0
MIN_TIME_REMAINING=60
MAX_TIME_REMAINING=1800

# =============================================================================
# Database
# =============================================================================
# SQLite (for development)
DATABASE_URL=sqlite:///./wenbot.db

# PostgreSQL (for production)
# DATABASE_URL=postgresql://bot_user:password@localhost:5432/wenbot

# =============================================================================
# API Security
# =============================================================================
# Set a strong token to protect management endpoints
API_TOKEN=your-secret-token-here

# =============================================================================
# Logging
# =============================================================================
LOG_LEVEL=INFO
LOG_FILE=logs/wenbot.log

# =============================================================================
# Settlement
# =============================================================================
SETTLEMENT_SOURCE=wunderground

# =============================================================================
# Cities for weather trading (comma-separated)
# =============================================================================
WEATHER_CITIES=nyc,chicago,miami,los_angeles,denver,seattle,atlanta,dallas,london,paris,seoul,sao_paulo,wellington,tokyo,toronto,ankara,shanghai,hong_kong,tel_aviv,munich,buenos_aires,lucknow,madrid,milan,singapore,warsaw,austin,san_francisco
